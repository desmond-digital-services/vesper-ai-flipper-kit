# Vesper AI Email System - SMTP Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# SMTP SETTINGS - Choose one provider below
# =============================================================================

# Gmail / Google Workspace
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here

# SendGrid (uncomment and fill in)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key

# Mailgun (uncomment and fill in)
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@yourdomain.com
# SMTP_PASSWORD=your-mailgun-password

# AWS SES (uncomment and fill in)
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=your-ses-access-key
# SMTP_PASSWORD=your-ses-secret-key

# =============================================================================
# EMAIL ADDRESSES
# =============================================================================

# The "From" address - must match your SMTP user for most providers
FROM_EMAIL=noreply@vespere.ai
FROM_NAME=Vesper AI

# Where replies go
REPLY_TO=help@vespere.ai

# =============================================================================
# DEBUG MODE
# =============================================================================

# Set to 'true' to log emails without actually sending
# Useful for testing templates and workflow
EMAIL_DEBUG=false

# =============================================================================
# NOTES
# =============================================================================

# 1. Gmail requires "App Password" not regular password
#    Go to: myaccount.google.com/security → App passwords

# 2. For production, use a service like SendGrid or Mailgun
#    They have better deliverability and analytics

# 3. Never commit .env to version control!
#    Add .env to your .gitignore file

# 4. Required Python version: 3.8+